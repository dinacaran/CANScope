# ── Claude ────────────────────────────────────────────────────────────────
.claude
.claude/
*.log
docs/
claude.md

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl
# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
# ── PyInstaller ───────────────────────────────────────────────────────────
# Keep CANScope.spec in source control; exclude build artefacts
*.spec.bak
# ── IDE / editors ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
# ── OS artefacts ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
# ── CAN Scope runtime files ───────────────────────────────────────────────
canscope_dev.log
canscope_config.json
# ── Diagnostics agent workspace + telemetry ───────────────────────────────
# Agent-generated candidate rules are a scratch workspace, not source.
config/diagnostics/generated/*.yaml
config/diagnostics/generated/*.yml
!config/diagnostics/generated/.gitkeep
# Per-run diagnostic telemetry JSON (logs/diagnostics/ is created at runtime).
logs/
*.blf
*.mf4
*.mdf
*.asc
*.dbc
# ── Test / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.coveragerc
# ── Test fixtures ─────────────────────────────────────────────────────────
# sample.blf and sample.asc are generated locally by tests/fixtures/_generate.py
# and intentionally NOT committed (already caught by *.blf / *.asc above).
# sample.dbc is a hand-written text fixture that IS committed — un-exclude it.
!tests/fixtures/sample.dbc
# ── Secrets ───────────────────────────────────────────────────────────────
*.pem
*.key
.env.*
secrets.json

# ── Others ───────────────────────────────────────────────────────────────
.claude/worktrees/
*.bak
*.xlsx
*.csv
AGENTS.md
