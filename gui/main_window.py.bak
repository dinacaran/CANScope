=pl-s1\u003ehas_store\u003c/span\u003e)","            \u003cspan class=pl-k\u003eelif\u003c/span\u003e \u003cspan class=pl-s1\u003ename\u003c/span\u003e \u003cspan class=pl-c1\u003ein\u003c/span\u003e \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003e_ACTS_NEEDS_FILE\u003c/span\u003e:","                \u003cspan class=pl-s1\u003eact\u003c/span\u003e.\u003cspan class=pl-c1\u003esetEnabled\u003c/span\u003e(\u003cspan class=pl-s1\u003ehas_file\u003c/span\u003e)","            \u003cspan class=pl-c\u003e# else: Open File, Load Config — always enabled\u003c/span\u003e","        \u003cspan class=pl-c\u003e# CAN Trace button requires raw frames (BLF/ASC with store)\u003c/span\u003e","        \u003cspan class=pl-s1\u003e_rfs\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-en\u003egetattr\u003c/span\u003e(\u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003estore\u003c/span\u003e, \u003cspan class=pl-s\u003e\u0026#39;raw_frame_store\u0026#39;\u003c/span\u003e, \u003cspan class=pl-c1\u003eNone\u003c/span\u003e) \u003cspan class=pl-k\u003eif\u003c/span\u003e \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003estore\u003c/span\u003e \u003cspan class=pl-k\u003eelse\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e","        \u003cspan class=pl-s1\u003ehas_trace\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-s1\u003ehas_store\u003c/span\u003e \u003cspan class=pl-c1\u003eand\u003c/span\u003e \u003cspan class=pl-s1\u003e_rfs\u003c/span\u003e \u003cspan class=pl-c1\u003e\u003cspan class=pl-c1\u003eis\u003c/span\u003e \u003cspan class=pl-c1\u003enot\u003c/span\u003e\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e \u003cspan class=pl-c1\u003eand\u003c/span\u003e \u003cspan class=pl-en\u003elen\u003c/span\u003e(\u003cspan class=pl-s1\u003e_rfs\u003c/span\u003e) \u003cspan class=pl-c1\u003e\u0026gt;\u0