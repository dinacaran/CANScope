003e, \u003cspan class=pl-s1\u003eparent\u003c/span\u003e: \u003cspan class=pl-v\u003eQWidget\u003c/span\u003e \u003cspan class=pl-c1\u003e|\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e, \u003cspan class=pl-s1\u003esplash\u003c/span\u003e\u003cspan class=pl-c1\u003e=\u003c/span\u003e\u003cspan class=pl-c1\u003eNone\u003c/span\u003e) \u003cspan class=pl-c1\u003e-\u0026gt;\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e:","        \u003cspan class=pl-en\u003esuper\u003c/span\u003e().\u003cspan class=pl-c1\u003e__init__\u003c/span\u003e(\u003cspan class=pl-s1\u003eparent\u003c/span\u003e)","        \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003eapp_name\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-s1\u003eapp_name\u003c/span\u003e","        \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003eversion\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-s1\u003eversion\u003c/span\u003e","        \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003esetWindowTitle\u003c/span\u003e(\u003cspan class=pl-s\u003ef\u0026#39;\u003cspan class=pl-s1\u003e\u003cspan class=pl-kos\u003e{\u003c/span\u003e\u003cspan class=pl-s1\u003eapp_name\u003c/span\u003e\u003cspan class=pl-kos\u003e}\u003c/span\u003e\u003c/span\u003e \u003cspan class=pl-s1\u003e\u003cspan class=pl-kos\u003e{\u003c/span\u003e\u003cspan class=pl-s1\u003eversion\u003c/span\u003e\u003cspan class=pl-kos\u003e}\u003c/span\u003e\u003c/span\u003e\u0026#39;\u003c/span\u003e)","        \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003eresize\u003c/span\u003e(\u003cspan class=pl-c1\u003e1700\u003c/span\u003e, \u003cspan class=pl-c1\u003e950\u003c/span\u003e)","","        \u003cspan class=pl-s1\u003eself\u003c/span\