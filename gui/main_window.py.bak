lass=pl-c1\u003eprocessEvents\u003c/span\u003e()","            \u003cspan class=pl-k\u003etry\u003c/span\u003e:","                \u003cspan class=pl-s1\u003echs\u003c/span\u003e, \u003cspan class=pl-s1\u003eids\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-en\u003eprescan_measurement\u003c/span\u003e(\u003cspan class=pl-s1\u003epath\u003c/span\u003e, \u003cspan class=pl-s1\u003eprogress\u003c/span\u003e\u003cspan class=pl-c1\u003e=\u003c/span\u003e\u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003e_log\u003c/span\u003e)","                \u003cspan class=pl-k\u003eif\u003c/span\u003e \u003cspan class=pl-s1\u003echs\u003c/span\u003e:","                    \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003e_prescan_cache\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e (\u003cspan class=pl-s1\u003epath\u003c/span\u003e, \u003cspan class=pl-s1\u003echs\u003c/span\u003e, \u003cspan class=pl-s1\u003eids\u003c/span\u003e)","                    \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003e_log\u003c/span\u003e(\u003cspan class=pl-s\u003ef\u0026#39;Pre-scan: found \u003cspan class=pl-s1\u003e\u003cspan class=pl-kos\u003e{\u003c/span\u003e\u003cspan class=pl-en\u003elen\u003c/span\u003e(\u003cspan class=pl-s1\u003echs\u003c/span\u003e)\u003cspan class=pl-kos\u003e}\u003c/span\u003e\u003c/span\u003e channel(s): \u0026#39;\u003c/span\u003e","                              \u003cspan class=pl-s\u003ef\u0026#39;\u003cspan class=pl-s1\u003e\u003cspan class=pl-kos\u003e{\u003c/span\u003e\u003cspan class=pl-s\u003e\u0026quot;, \u0026quot;\u003c/span\u003e.\u003cspan class=pl-c1\u003ejoin\u003c/span\u003e(\u003cspan class=pl-s\u003ef\u0026quot;CAN \u003cspan class=pl-s1\u003e\u003cspan class=pl-kos\u003e{\u003c/span\u003e\u003cspan class=pl-s1\u003ec\u003c/span\u003e\u003cspan class=pl-kos\u003e}\u003c/span\u003e\u003c/span\u003e\u0026quot;\u003