003c/span\u003e(\u003cspan class=pl-s1\u003erow\u003c/span\u003e, \u003cspan class=pl-c1\u003e1\u003c/span\u003e, \u003cspan class=pl-en\u003eQTableWidgetItem\u003c/span\u003e(\u003cspan class=pl-s1\u003edesc\u003c/span\u003e))","        \u003cspan class=pl-s1\u003elayout\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-en\u003eQVBoxLayout\u003c/span\u003e(\u003cspan class=pl-s1\u003edlg\u003c/span\u003e)","        \u003cspan class=pl-s1\u003elayout\u003c/span\u003e.\u003cspan class=pl-c1\u003eaddWidget\u003c/span\u003e(\u003cspan class=pl-s1\u003etbl\u003c/span\u003e)","        \u003cspan class=pl-s1\u003eclose_btn\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-en\u003eQPushButton\u003c/span\u003e(\u003cspan class=pl-s\u003e\u0026#39;Close\u0026#39;\u003c/span\u003e)","        \u003cspan class=pl-s1\u003eclose_btn\u003c/span\u003e.\u003cspan class=pl-c1\u003eclicked\u003c/span\u003e.\u003cspan class=pl-c1\u003econnect\u003c/span\u003e(\u003cspan class=pl-s1\u003edlg\u003c/span\u003e.\u003cspan class=pl-c1\u003eaccept\u003c/span\u003e)","        \u003cspan class=pl-s1\u003elayout\u003c/span\u003e.\u003cspan class=pl-c1\u003eaddWidget\u003c/span\u003e(\u003cspan class=pl-s1\u003eclose_btn\u003c/span\u003e)","        \u003cspan class=pl-s1\u003edlg\u003c/span\u003e.\u003cspan class=pl-c1\u003eexec\u003c/span\u003e()","","    \u003cspan class=pl-k\u003edef\u003c/span\u003e \u003cspan class=pl-en\u003e_on_worker_progress\u003c/span\u003e(\u003cspan class=pl-s1\u003eself\u003c/span\u003e, \u003cspan class=pl-s1\u003emessage\u003c/span\u003e: \u003cspan class=pl-smi\u003estr\u003c/span\u003e) \u003cspan class=pl-c1\u003e-\u0026gt;\u003c/span\u003e \u003cspan class=pl-c1\u003eNone\u003c/span\u003e:","        \u003cspan class=pl-s1\u003eself\u003c/span\u003e.\u003cspan class=pl-c1\u003e_log\u003c/span\u003e(\u003cspan class=pl-s1\u003emessage\u003c/span\u003e)","        \u003cspan class=pl-s1\u003eself\